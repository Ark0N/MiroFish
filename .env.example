# LLM Configuration (Anthropic Claude)
LLM_API_KEY=sk-ant-your_api_key_here
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_MODEL_NAME=claude-haiku-4-5-20251001

# Neo4j (Knowledge Graph storage)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish_neo4j

# Embeddings for Graphiti semantic search
# Option 1: Local via Ollama (default, no API key needed)
#   Run: ollama pull nomic-embed-text
EMBEDDER_BASE_URL=http://localhost:11434/v1
EMBEDDER_MODEL=nomic-embed-text
EMBEDDER_DIM=768
# Option 2: Voyage AI (set this to use Voyage instead of local)
# VOYAGE_API_KEY=your_voyage_api_key_here

# CORS (comma-separated origins, defaults to localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Local LLM for simulation (routes all agent calls here, $0 cost)
# Requires Ollama on a GPU machine with qwen3-sim model:
#   1. ollama pull qwen3:32b
#   2. Create no-think variant (see docs/ollama-setup.md or use API):
#      curl http://<gpu-host>:11434/api/create -d '{"model":"qwen3-sim","from":"qwen3:32b","template":"...","parameters":{"num_ctx":16384}}'
# LLM_BOOST_API_KEY=ollama
# LLM_BOOST_BASE_URL=http://your-gpu-machine:11434/v1
# LLM_BOOST_MODEL_NAME=qwen3-sim

# Simulation & Report Agent tuning
# OASIS_DEFAULT_MAX_ROUNDS=10
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5
