# LLM Configuration (Anthropic Claude)
LLM_API_KEY=sk-ant-your_api_key_here
LLM_BASE_URL=https://api.anthropic.com/v1/
LLM_MODEL_NAME=claude-haiku-4-5-20251001

# Neo4j (Knowledge Graph storage)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish_neo4j

# Voyage AI (embeddings for Graphiti semantic search)
VOYAGE_API_KEY=your_voyage_api_key_here

# CORS (comma-separated origins, defaults to localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Second LLM for parallel simulation speedup
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=
